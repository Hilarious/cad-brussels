# --- Database ---
DATABASE_URI=postgres://cad:cad@localhost:5432/cad

# --- Payload ---
PAYLOAD_SECRET=replace-with-32+-random-bytes
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000

# --- Public site URL (used by sitemap, OG tags) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- S3 / R2 storage (media uploads) ---
S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
S3_BUCKET=cad-media
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto

# --- Email (Resend) ---
RESEND_API_KEY=
RESEND_FROM="CAD Brussels <noreply@cad.be>"
CONTACT_EMAIL=secretariat@cad.be

# --- Anti-spam (Cloudflare Turnstile) ---
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
