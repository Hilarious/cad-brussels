{
  "name": "cad-brussels",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "verify": "node scripts/verify.mjs",
    "verify:ui": "node scripts/verify-ui.mjs",
    "payload": "payload",
    "generate:types": "payload generate:types",
    "generate:importmap": "payload generate:importmap",
    "seed": "tsx --env-file=.env scripts/seed.ts",
    "seed:extras": "tsx --env-file=.env scripts/seed-extras.ts",
    "seed:all": "pnpm seed && pnpm seed:extras",
    "fix:header": "tsx --env-file=.env scripts/fix-header.ts",
    "inspect": "tsx --env-file=.env scripts/inspect.ts",
    "reset:content": "tsx --env-file=.env scripts/reset-content.ts",
    "test": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "^3.7.0",
    "@payloadcms/next": "^3.7.0",
    "@payloadcms/richtext-lexical": "^3.7.0",
    "@payloadcms/storage-s3": "^3.7.0",
    "@payloadcms/ui": "^3.7.0",
    "next": "^15.1.0",
    "next-intl": "^3.26.0",
    "payload": "^3.7.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.53.0",
    "sharp": "^0.33.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.7.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.0"
  },
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.9.0"
  }
}
